# =============================================================================
# WhatsApp AI Support Engine — Environment
# Copy to .env and fill in. Never commit .env to git.
# =============================================================================

# ----- General -----
TZ=Africa/Cairo
APP_BASE_URL=http://localhost:3000        # public URL of the dashboard
HTTP_PORT=80
HTTPS_PORT=443

# ----- PostgreSQL (system DB + pgvector) -----
POSTGRES_USER=was
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=was_engine
POSTGRES_PORT=5432
# Used by the dashboard container (host = db inside the compose network):
DATABASE_URL=postgres://was:change_me_strong_password@db:5432/was_engine

# --- Managed Postgres / Supabase (e.g. Vercel deploy) ---
# Point DATABASE_URL at your provider's SESSION pooler / direct URI (not the
# transaction pooler, so SET search_path persists). Then:
#   DB_SCHEMA  = the schema that holds the engine tables (Supabase isolated: "was")
#   PGSSL      = require   (managed Postgres needs SSL; auto-on for *.supabase.com)
#   DB_POOL_MAX= small for serverless (default 5)
DB_SCHEMA=
PGSSL=
DB_POOL_MAX=5

# ----- Dashboard -----
DASHBOARD_PORT=3000
# Shared secret between dashboard <-> n8n for internal API calls:
ENGINE_INTERNAL_TOKEN=change_me_internal_token

# ----- Vector DB (RAG) -----
# pgvector  -> uses Postgres (default, simplest, one container)
# qdrant    -> uses the dedicated Qdrant container
VECTOR_PROVIDER=pgvector
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ----- AI provider (provider-agnostic adapter) -----
# AI_PROVIDER selects the chat adapter:
#   openai     -> OpenAI or ANY OpenAI-compatible endpoint (Ollama, LM Studio,
#                 vLLM, Together, Groq, OpenRouter, local server, ...)
#   anthropic  -> Anthropic Claude
#
# Local / self-hosted example (Ollama):
#   AI_PROVIDER=openai
#   AI_BASE_URL=http://host.docker.internal:11434/v1
#   AI_API_KEY=ollama
#   AI_CHAT_MODEL=llama3.1
#   AI_EMBEDDING_MODEL=nomic-embed-text
#   AI_EMBEDDING_DIM=768
AI_PROVIDER=openai
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-...
AI_CHAT_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_EMBEDDING_DIM=1536
# Only if AI_PROVIDER=anthropic:
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# IMPORTANT: AI_EMBEDDING_DIM must match the vector column dimension in the DB.
# Default schema uses 1536. If you change the embedding model, set
# EMBEDDING_DIM in sql/schema.sql (vector(N)) to the same value before first boot.

# ----- n8n -----
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
# 32+ char random string; required so saved credentials survive restarts:
N8N_ENCRYPTION_KEY=change_me_32_char_minimum_secret_key

# ----- WhatsApp Cloud API (Meta) -----
# These are PER-BUSINESS and normally stored in the dashboard (integrations table).
# The values below are only a global fallback / single-tenant convenience.
WHATSAPP_VERIFY_TOKEN=choose_any_verify_token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
WHATSAPP_API_VERSION=v21.0
