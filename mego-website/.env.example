# =============================================================================
# Mego website — Environment variables
# Copy this file to .env.local and fill in the values. Never commit .env.local.
# =============================================================================

# Public site URL, used for SEO metadata, sitemap.xml and robots.txt.
NEXT_PUBLIC_SITE_URL=https://mego-gomsa.com

# -----------------------------------------------------------------------------
# Supabase (optional) — only needed if you want to store service requests
# in a database and use the /admin/requests dashboard.
# If left empty, the request form still works fully via WhatsApp.
# -----------------------------------------------------------------------------

# Supabase project URL (Settings -> API).
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (Settings -> API). Currently unused by the client
# directly (requests are saved through the server route), but kept for
# future client-side Supabase usage.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (Settings -> API). Server-only, used by
# /api/requests and the /admin/requests dashboard to read/write data.
# NEVER expose this key to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Admin dashboard
# -----------------------------------------------------------------------------

# Password to log in to /admin/requests. Choose a strong value in production.
ADMIN_PASSWORD=change-me
